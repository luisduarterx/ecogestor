// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model users{
  id Int @id @default(autoincrement())
  nome String
  email String @unique
  senha String
  perfil_id Int
  criado_em DateTime @default(now())
  atualizado_em DateTime @default(now())
  sessions sessions[]
  perfil perfis @relation(fields: [perfil_id], references: [id])

}
model sessions{
  id String @id @default(uuid()) @db.VarChar(36)
  token String @unique @db.VarChar(96)
  user_id Int 
  usuario users @relation(fields: [user_id],references:[id])
  criado_em DateTime @default(now())
  expira_em DateTime 
}
model perfis{
  id Int @id @default(autoincrement())
  nome String
  permissoes String[]
  atualizado_em DateTime @default(now())
  usuarios users[]
}
model registros{
  id Int @id @default(autoincrement())
  nome String
  status Boolean @default(true)
  tipo_registro tipo_registro
  email String?
  whatsapp String?
  cpf String? @unique
  cnpj String? @unique
  ie           String?
  data_nascimento DateTime?
  cep          String?
  logradouro   String?
  numero       String?
  complemento  String?
  bairro       String?
  cidade       String?
  estado       String?
  criado_em DateTime @default(now())
  atualizado_em DateTime @default(now())
}
enum tipo_registro{
  F
  J
}

 