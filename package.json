{
  "name": "ecogestor",
  "version": "1.0.0",
  "description": "Sistema de gerenciamento para estabelecimentos de compra e venda de materiais recicláveis.",
  "homepage": "https://github.com/luisduarterx/ecogestor#readme",
  "bugs": {
    "url": "https://github.com/luisduarterx/ecogestor/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/luisduarterx/ecogestor.git"
  },
  "license": "ISC",
  "author": "",
  "main": "index.js",
  "scripts": {
    "dev": " npm run services:up && npm run wait-for-postgres && npm run migration:up && next dev ",
    "services:up": "docker compose -f infra/compose.yaml up -d",
    "services:stop": "docker compose -f infra/compose.yaml down",
    "migration:create": "prisma migrate dev",
    "migration:up": "prisma migrate deploy",
    "build": "next build",
    "start": "next start",
    "lint:check": "prettier --check .",
    "lint:fix": "prettier --write .",
    "test": "npm run services:up && npm run wait-for-postgres && concurrently --names next,jest --kill-others -s command-jest 'next dev' 'jest --runInBand'",
    "test:watch": "jest --watchAll --runInBand",
    "wait-for-postgres": "node infra/scripts/wait-for-postgres.js"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "async-retry": "^1.3.3",
    "bcryptjs": "^3.0.3",
    "cookie": "^1.1.1",
    "next": "^16.1.1",
    "next-connect": "^1.0.0-next.4",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "swr": "^2.3.8",
    "uuid": "^11.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.3.1",
    "@commitlint/config-conventional": "^20.3.1",
    "@faker-js/faker": "^9.7.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/jest": "^30.0.0",
    "concurrently": "^9.2.1",
    "dotenv": "^17.2.3",
    "jest": "^30.2.0",
    "prettier": "^3.7.4",
    "prisma": "^7.5.0",
    "set-cookie-parser": "^3.0.1"
  }
}
